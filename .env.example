# StockLens-AI local environment template
# Copy to .env for local development. Do not commit .env files.

# Safe default for demos, screenshots, and CI. Mock mode requires no provider keys.
# Set to false to enable real data providers (requires API keys below).
MOCK_MODE=true
APP_ENV=local
LOG_LEVEL=info

# API service settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Market data provider: mock | yfinance
# yfinance is free and requires no API key or base URL.
MARKET_DATA_PROVIDER=yfinance

# News provider: mock | finnhub
# Finnhub requires a free API key from https://finnhub.io
NEWS_PROVIDER=finnhub
NEWS_API_KEY=
# Fundamentals provider: mock | yfinance
# yfinance is free and requires no API key.
FUNDAMENTALS_PROVIDER=yfinance

# AI explanation provider: mock | openai | anthropic | glm | openrouter
# When set to a real provider, AI generates educational conclusions.
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Vision / OCR provider: mock | tesseract
VISION_PROVIDER=mock

# Optional persistence settings for future implementation.
DATABASE_URL=

# Use a generated local value if/when sessions are implemented. Do not commit real secrets.
SESSION_SECRET=

# Legacy aliases (optional)
OPENAI_API_KEY=
