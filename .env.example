# StockLens-AI local environment template
# Copy to .env for local development. Do not commit .env files.

APP_ENV=local
LOG_LEVEL=info

# API service settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Market data provider: yfinance
# yfinance is used for live/delayed OHLCV data and requires no API key.
MARKET_DATA_PROVIDER=yfinance

# News provider: finnhub
# Finnhub requires a free API key from https://finnhub.io.
NEWS_PROVIDER=finnhub
NEWS_API_KEY=

# Fundamentals provider: yfinance
# yfinance is used for fundamentals and requires no API key.
FUNDAMENTALS_PROVIDER=yfinance

# AI explanation provider: openai | anthropic | glm | openrouter
# When set, AI generates report conclusions. Leave empty to disable.
AI_PROVIDER=glm
AI_API_KEY=
AI_MODEL=glm-5.1

# Vision / OCR provider: tesseract
VISION_PROVIDER=tesseract

# Optional VLM chart metadata provider: openai | anthropic | glm | openrouter
# May help detect ticker/timeframe, chart bounds, and visible price-axis labels.
# It must not generate candle OHLC values or decide screenshot signals.
CHART_VISION_PROVIDER=
CHART_VISION_API_KEY=
CHART_VISION_MODEL=gpt-4o-mini

# Optional persistence settings for future implementation.
DATABASE_URL=
SESSION_SECRET=
