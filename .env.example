# StockLens-AI local environment template
# Copy to .env for local development. Do not commit .env files.

# Safe default for demos, screenshots, and CI. Mock mode requires no provider keys.
MOCK_MODE=true
APP_ENV=local
LOG_LEVEL=info

# API service settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Optional market-data provider settings. Leave blank in mock mode.
MARKET_DATA_PROVIDER=mock
MARKET_DATA_API_KEY=
MARKET_DATA_BASE_URL=

# Optional AI provider settings. Leave blank in mock mode.
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=

# Optional persistence settings for future implementation.
DATABASE_URL=

# Use a generated local value if/when sessions are implemented. Do not commit real secrets.
SESSION_SECRET=

# Optional future live provider keys. Keep these backend-only.
NEWS_API_KEY=
FUNDAMENTALS_API_KEY=
OPENAI_API_KEY=
